Average = struct
  count: Nat
  total: Real
end

accumulate(average: *Average, value: Real) Nothing = begin
  average.count += 1
  average.total += value
end

start() Nothing = begin
  data = [3.5, 2.3, 7.32]
  average = Average(count=0, total=0)
  for element in data
    accumulate(&average, element)
  end
  print(average.total / average.count)
end
