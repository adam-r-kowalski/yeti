Average = struct
  count: Natural
  total: Real
end

function accumulate(average: *Average, value: Real) Nothing
  average.count += 1
  average.total += value
end

function start() Natural
  data = [3.5, 2.3, 7.32]
  average = Average(count=0, total=0)
  for element in data
    accumulate(&average, element)
  end
  print(average.total / average.count)
end
