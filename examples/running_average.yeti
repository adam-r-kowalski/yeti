Average = struct
  count: U64
  total: F64
end

accumulate = fn(average: *Average, value: F64) -> Void
  average.count += 1
  average.total += value
end

start = fn() -> Void
  data = [3.5, 2.3, 7.32]
  average = Average(count=0, total=0)
  for element in data
    accumulate(&average, element)
  end
  print(average.total / average.count)
end
