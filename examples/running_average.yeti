u64 = int(0, 2^64)

Average = (count: u64, total: f64)


accumulate(average: &mut Average, value: f64) void =
  average.count += 1
  average.total += value


start() u64 =
  data = [3.5, 2.3, 7.32]
  average = Average(count=0, total=0)
  for element in data:
    accumulate(&mut average, element))
  print(average.total / average.count)
