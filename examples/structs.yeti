Rectangle = struct
  width: f64
  height: f64
end

area = fn(r: Rectangle): f64
  r.width * r.height
end

Square = struct
  length: f64
end

area = fn(s: Square): f64
  s.length * s.length
end

Triangle = struct
  base: f64
  height: f64
end

area = fn(t: Triangle): f64
  t.base * t.height / 2
end

start = fn(): f64
  r = Rectangle(5, 4)
  s = Square(5)
  t = Triangle(5, 4)
  area(t)
end
