struct Rectangle {
  width: f64
  height: f64
}

area(r: Rectangle): f64 {
  r.width * r.height
}

struct Square {
  length: f64
}

area(s: Square): f64 {
  s.length * s.length
}

struct Triangle {
  base: f64
  height: f64
}

area(t: Triangle): f64 {
  t.base * t.height / 2
}

start(): f64 {
  r = Rectangle(5, 4)
  s = Square(5)
  t = Triangle(5, 4)
  r.area
}
