fd_write = foreign_import("wasi_unstable", "fd_write", Fn(file_descriptor: i32, iovs: **u8, iovs_len: i32, nwritten: *i32): i32)

print = fn(text: []u8): void
  iov_base = cast(**u8, 1000)
  iov_len = cast(*i32, 1004)
  nwritten = cast(*i32, 1008)
  *iov_base = text.ptr
  *iov_len = text.len
  result = fd_write(1, iov_base, 1, nwritten)
end

start = fn(): void
  print("hello\n")
  print("doing work\n")
  print("goodbye\n")
end
