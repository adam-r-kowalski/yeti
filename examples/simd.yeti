Vec4 = struct
  a: i32
  b: i32
  c: i32
  d: i32
end

start = fn(): Vec4
  x0 = cast(*i32, 0)
  x1 = x0 + 1
  x2 = x1 + 1
  x3 = x2 + 1
  
  y0 = x3 + 1
  y1 = y0 + 1
  y2 = y1 + 1
  y3 = y2 + 1
  
  z0 = y3 + 1
  z1 = z0 + 1
  z2 = z1 + 1
  z3 = z2 + 1

  *x0 = 10
  *x1 = 20
  *x2 = 30
  *x3 = 40
  
  *y0 = 50
  *y1 = 60
  *y2 = 70
  *y3 = 80

  x = cast(*i32x4, 0)
  y = x + 1
  z = y + 1

  *z = *x + *y

  Vec4(*z0, *z1, *z2, *z3)
end
