start() Nat = begin
  x = 10
  y = 15
  z = if x > y then
    50
  otherwise if y > x then
    20
  otherwise
    30
  end
end

while_loop() Nat = begin
  i = 0
  while i < 10
    print(i)
    i += 1
  end
end

for_loop() Nat = begin
  for i in range(10)
    print(i)
  end
end

sum_of_even_perfect_squares_under_50() Nat =
  naturals()
  |> map((x) = x * x)
  |> filter((x) = x % 2 == 0)
  |> take_while((x) = x < 50)
  |> reduce((acc, x) = acc + x)
