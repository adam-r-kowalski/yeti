start = fn() -> U64
  x = 10
  y = 15
  z = when
    x > y then 50 end
    y > x then 20 end
    _ then 32 end
  end
end

while_loop = fn() -> Void
  i = 0
  while i < 10
    print(i)
    i += 1
  end
end

for_loop = fn() -> Void
  for i in range(10)
    print(i)
  end
end

sum_of_even_perfect_squares_under_50 = fn() -> U64
  naturals()
  |> map(fn(x) x * x end)
  |> filter(fn(x) x % 2 == 0 end)
  |> take_while(fn(x) x < 50 end)
  |> reduce(fn(acc, x) acc + x end)
end

VTable = fn(Buffer: Type) Type
  struct
    write: Fn(to: Buffer, bytes: Array(U8)) -> Void
    read: Fn(from: Buffer, bytes: U64, into: *Array(U8)) -> Void
  end
end
