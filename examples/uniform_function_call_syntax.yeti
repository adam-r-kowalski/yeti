struct Rectangle {
  width: f64
  height: f64
}

area(r: Rectangle) f64 {
  r.width * r.height
}

struct Square {
  length: f64
}

area(s: Square) f64 {
  s.length * s.length
}

min(x: f64, y: f64) f64 {
  if x < y { x } else { y }
}

square(x: f64) f64 {
  x * x
}

line(m: f64, x: f64, b: f64) f64 {
  m * x + b
}

start() f64 {
  r = Rectangle(20, 10)
  s = Square(20)
  s.area.min(150).square.line(10, 5, _)
}

